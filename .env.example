# 复制为 .env 后在本机或服务器使用；.env 会被 .gitignore 忽略。
# 不要把真实公网 IP、域名、密码、密钥提交到 Git。

# WireGuard 公网入口。示例值不可直接用于生产。
SERVER_ENDPOINT=vpn.example.com
VPN_PORT=41194
VPN_CIDR=10.66.0.0/24
SERVER_VPN_IP=10.66.0.1
NETWORK_INTERFACE=eth0
DNS_SERVERS=223.5.5.5,119.29.29.29
MTU=1280

# 管理入口建议只绑定 VPN 内网地址或本机回环地址。
PUBLIC_STATUS_DOMAIN=chinavpn.example.com
MANAGEMENT_BIND_HOST=10.66.0.1
MANAGEMENT_BIND_PORT=8443
